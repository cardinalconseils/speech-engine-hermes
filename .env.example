# ElevenLabs API key (from https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=

# OpenRouter API key (from https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Speech Engine ID (filled by create_engine.py)
SPEECH_ENGINE_ID=

# Public WebSocket URL of your server (wss:// for production, ws:// for local)
# Example: wss://abc123.ngrok.io/ws
WS_URL=

# LLM model to use via OpenRouter (default: deepseek/deepseek-v4-flash)
# Other options: anthropic/claude-sonnet-4, google/gemini-2.5-flash, openai/gpt-4o
LLM_MODEL=deepseek/deepseek-v4-flash

# System prompt for the LLM
SYSTEM_PROMPT=You are a helpful voice assistant. Keep responses concise and conversational. Speak in short sentences. Never use markdown or special characters.
